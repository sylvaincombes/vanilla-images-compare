{
    "$schema": "https://biomejs.dev/schemas/2.4.9/schema.json",
    "formatter": {
        "enabled": true
    },
    "linter": {
        "enabled": true
    },
    "files": {
        "includes": ["**", "!!**/build"]
    },
    "overrides": [
        {
            "includes": ["src/tests/**"],
            "linter": {
                "rules": {
                    "style": {
                        "noNonNullAssertion": "off"
                    },
                    "suspicious": {
                        "noExplicitAny": "off"
                    }
                }
            }
        }
    ]
}
